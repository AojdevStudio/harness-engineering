{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@symphony/core": ["packages/core/src/index.ts"],
      "@symphony/db": ["packages/db/src/index.ts"],
      "@symphony/evidence": ["packages/evidence/src/index.ts"],
      "@symphony/orchestrator": ["packages/orchestrator/src/index.ts"],
      "@symphony/runner": ["packages/runner/src/index.ts"],
      "@symphony/server": ["apps/server/src/index.ts"],
      "@symphony/tracker-linear": ["packages/tracker-linear/src/index.ts"],
      "@symphony/workflow": ["packages/workflow/src/index.ts"],
      "@symphony/workspace-git": ["packages/workspace-git/src/index.ts"]
    },
    "noEmit": true
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts"]
}
